---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
}

const { title, description = 'Open-source BI platform powered by drizzle-cube. Self-service analytics, AI agentic notebooks, and a full semantic layer — self-host or deploy instantly on Drizby Cloud.', ogImage = 'https://www.drizby.com/images/drizby_2.png', canonicalPath = '' } = Astro.props;
const url = 'https://www.drizby.com';
const canonical = `${url}${canonicalPath}`;
const currentPath = Astro.url.pathname;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" sizes="512x512" href="/logo.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0f1117" />
    <script is:inline>
      (function(){var t=localStorage.getItem('theme');if(!t)t=window.matchMedia('(prefers-color-scheme:light)').matches?'light':'dark';if(t==='light'){document.documentElement.setAttribute('data-theme','light');document.querySelector('meta[name="theme-color"]').setAttribute('content','#f8f9fc')}})();
    </script>
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Guidemode Limited" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Drizby" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <nav class="top-nav">
      <div class="nav-inner">
        <a href="/" class="nav-brand">
          <img src="/logo.png" alt="Drizby logo" class="nav-logo" />
          <span class="nav-title">Drizby</span>
        </a>
        <button class="mobile-toggle" aria-label="Toggle menu" onclick="document.querySelector('.nav-links').classList.toggle('open')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
        <div class="nav-links">
          <div class="nav-dropdown" onclick="this.classList.toggle('active')">
            <button class="nav-link dropdown-trigger desktop-only" type="button">Features <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
            <div class="dropdown-menu">
              <div class="dropdown-menu-inner">
                <a href="/features/semantic-layer" class:list={[{ active: currentPath.includes('semantic-layer') }]}>Semantic Layer</a>
                <a href="/features/dashboards" class:list={[{ active: currentPath.includes('dashboards') }]}>Dashboards</a>
                <a href="/features/agentic-notebooks" class:list={[{ active: currentPath.includes('agentic-notebooks') }]}>Agentic Notebooks</a>
                <a href="/features/mcp-server" class:list={[{ active: currentPath.includes('mcp-server') }]}>MCP Server</a>
                <a href="/features/users-and-groups" class:list={[{ active: currentPath.includes('users-and-groups') }]}>Users & Groups</a>
              </div>
            </div>
          </div>
          <div class="mobile-features">
            <span class="mobile-features-label">Features</span>
            <a href="/features/semantic-layer" class:list={["nav-link", { active: currentPath.includes('semantic-layer') }]}>Semantic Layer</a>
            <a href="/features/dashboards" class:list={["nav-link", { active: currentPath.includes('dashboards') }]}>Dashboards</a>
            <a href="/features/agentic-notebooks" class:list={["nav-link", { active: currentPath.includes('agentic-notebooks') }]}>Agentic Notebooks</a>
            <a href="/features/mcp-server" class:list={["nav-link", { active: currentPath.includes('mcp-server') }]}>MCP Server</a>
            <a href="/features/users-and-groups" class:list={["nav-link", { active: currentPath.includes('users-and-groups') }]}>Users & Groups</a>
          </div>
          <a href="/pricing" class:list={["nav-link", { active: currentPath.includes('pricing') }]}>Pricing</a>
          <a href="https://github.com/cliftonc/drizby" target="_blank" rel="noopener" class="nav-link">
            <svg class="gh-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            GitHub
          </a>
          <button class="theme-toggle nav-link" aria-label="Toggle theme" type="button">
            <svg class="theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
          <a href="https://cloud.drizby.com" target="_blank" rel="noopener" class="nav-link nav-cta">Drizby Cloud</a>
        </div>
      </div>
    </nav>

    <script>
      document.addEventListener('click', (e) => {
        const dropdown = document.querySelector('.nav-dropdown');
        if (dropdown && !dropdown.contains(e.target as Node)) {
          dropdown.classList.remove('active');
        }
      });
    </script>

    <script is:inline>
      (function() {
        function getTheme() {
          const stored = localStorage.getItem('theme');
          if (stored === 'light' || stored === 'dark') return stored;
          return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        }
        function applyTheme(theme) {
          if (theme === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
          } else {
            document.documentElement.removeAttribute('data-theme');
          }
          document.querySelectorAll('meta[name="theme-color"]').forEach(function(m) {
            m.setAttribute('content', theme === 'light' ? '#f8f9fc' : '#0f1117');
          });
        }
        applyTheme(getTheme());
        document.addEventListener('DOMContentLoaded', function() {
          var btn = document.querySelector('.theme-toggle');
          if (btn) {
            btn.addEventListener('click', function() {
              var current = getTheme();
              var next = current === 'dark' ? 'light' : 'dark';
              localStorage.setItem('theme', next);
              applyTheme(next);
            });
          }
        });
        window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function(e) {
          if (!localStorage.getItem('theme')) {
            applyTheme(e.matches ? 'light' : 'dark');
          }
        });
      })();
    </script>

    <slot />

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-grid">
          <div class="footer-brand">
            <a href="/" class="footer-logo-link">
              <img src="/logo.png" alt="Drizby" class="footer-logo" />
              <span>Drizby</span>
            </a>
            <p class="footer-tagline">Open-source BI platform powered by <a href="https://github.com/cliftonc/drizzle-cube">drizzle-cube</a></p>
          </div>
          <div class="footer-col">
            <h4>Features</h4>
            <a href="/features/semantic-layer">Semantic Layer</a>
            <a href="/features/dashboards">Dashboards</a>
            <a href="/features/agentic-notebooks">Agentic Notebooks</a>
            <a href="/features/mcp-server">MCP Server</a>
            <a href="/features/users-and-groups">Users & Groups</a>
          </div>
          <div class="footer-col">
            <h4>Resources</h4>
            <a href="https://github.com/cliftonc/drizby" target="_blank" rel="noopener">GitHub</a>
            <a href="https://github.com/cliftonc/drizzle-cube" target="_blank" rel="noopener">drizzle-cube</a>
            <a href="https://try.drizzle-cube.dev" target="_blank" rel="noopener">Try Drizzle-Cube</a>
            <a href="https://cloud.drizby.com" target="_blank" rel="noopener">Drizby Cloud</a>
          </div>
          <div class="footer-col">
            <h4>Legal</h4>
            <a href="/privacy">Privacy Policy</a>
            <a href="/terms">Terms of Service</a>
            <a href="/security">Security</a>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} Drizby. MIT License.</p>
          <p>Made by <a href="https://github.com/cliftonc" target="_blank" rel="noopener">Clifton Cunningham</a></p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0f1117;
    --surface: #1a1d27;
    --border: #2a2d3a;
    --text: #e1e4eb;
    --muted: #8b8fa3;
    --accent: #6366f1;
    --accent-hover: #818cf8;
    --nav-bg: rgba(15, 17, 23, 0.85);
    --shadow-drop: rgba(0, 0, 0, 0.3);
    --accent-tint: rgba(99, 102, 241, 0.08);
    --accent-tint-strong: rgba(99, 102, 241, 0.1);
  }

  [data-theme="light"] {
    --bg: #f8f9fc;
    --surface: #ffffff;
    --border: #e2e4ea;
    --text: #1a1d27;
    --muted: #6b7084;
    --accent: #6366f1;
    --accent-hover: #4f46e5;
    --nav-bg: rgba(248, 249, 252, 0.85);
    --shadow-drop: rgba(0, 0, 0, 0.08);
    --accent-tint: rgba(99, 102, 241, 0.06);
    --accent-tint-strong: rgba(99, 102, 241, 0.08);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--bg);
    color: var(--text);
  }

  a { color: var(--accent); text-decoration: none; }
  a:hover { color: var(--accent-hover); }
</style>

<style>
  /* Top Navigation */
  .top-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--nav-bg);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: 1150px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text);
  }
  .nav-brand:hover { color: var(--text); }
  .nav-logo { height: 1.75rem; width: auto; filter: drop-shadow(0 0 8px rgba(99, 102, 241, 0.3)); }
  .nav-title {
    font-size: 1.2rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--text) 0%, var(--accent-hover) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 0.75rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav-link:hover { color: var(--text); background: var(--accent-tint); }
  .gh-icon { width: 1em; height: 1em; }
  .nav-cta {
    background: var(--accent);
    color: #fff !important;
    border-radius: 6px;
    margin-left: 0.25rem;
  }
  .nav-cta:hover { background: var(--accent-hover); color: #fff !important; }

  /* Theme toggle */
  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    padding: 0.4rem;
    border-radius: 6px;
  }
  .theme-toggle svg { width: 1.1rem; height: 1.1rem; }
  .theme-icon-sun { display: none; }
  .theme-icon-moon { display: block; }
  :global([data-theme="light"]) .theme-icon-sun { display: block; }
  :global([data-theme="light"]) .theme-icon-moon { display: none; }

  /* Dropdown */
  .nav-dropdown { position: relative; }
  .dropdown-trigger {
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }
  .chevron { width: 0.75em; height: 0.75em; transition: transform 0.2s; }
  .dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    padding-top: 0.35rem;
    min-width: 200px;
  }
  .dropdown-menu-inner {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.4rem;
    box-shadow: 0 8px 24px var(--shadow-drop);
  }
  .dropdown-menu a {
    display: block;
    padding: 0.5rem 0.75rem;
    font-size: 0.85rem;
    color: var(--muted);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .dropdown-menu a:hover, .dropdown-menu a.active {
    color: var(--text);
    background: var(--accent-tint-strong);
  }
  .nav-dropdown:hover .dropdown-menu,
  .nav-dropdown.active .dropdown-menu { display: block; }
  .nav-dropdown:hover .chevron,
  .nav-dropdown.active .chevron { transform: rotate(180deg); }

  /* Mobile features (direct links, hidden on desktop) */
  .mobile-features { display: none; }

  /* Mobile toggle */
  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--text);
    cursor: pointer;
    padding: 0.25rem;
  }
  .mobile-toggle svg { width: 1.5rem; height: 1.5rem; }

  /* Footer */
  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--surface);
    padding: 3rem 1.5rem 1.5rem;
    margin-top: 4rem;
  }
  .footer-inner {
    max-width: 1150px;
    margin: 0 auto;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2rem;
  }
  .footer-brand { display: flex; flex-direction: column; gap: 0.75rem; }
  .footer-logo-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text);
    text-decoration: none;
    font-weight: 700;
    font-size: 1.1rem;
  }
  .footer-logo-link:hover { color: var(--text); }
  .footer-logo { height: 1.75rem; width: auto; }
  .footer-tagline { font-size: 0.85rem; color: var(--muted); line-height: 1.5; }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-col h4 {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text);
    margin-bottom: 0.25rem;
  }
  .footer-col a {
    font-size: 0.85rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-col a:hover { color: var(--text); }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--muted);
  }
  .footer-bottom a { color: var(--muted); }
  .footer-bottom a:hover { color: var(--text); }

  @media (max-width: 768px) {
    .mobile-toggle { display: block; }
    .nav-links {
      display: none;
      position: absolute;
      top: 3.5rem;
      left: 0;
      right: 0;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      flex-direction: column;
      align-items: stretch;
      padding: 0.75rem;
      gap: 0.25rem;
    }
    .nav-links.open { display: flex; }
    .nav-link { width: 100%; }
    .nav-cta { margin-left: 0; text-align: center; justify-content: center; }
    .nav-dropdown { display: none; }
    .mobile-features {
      display: flex;
      flex-direction: column;
    }
    .mobile-features-label {
      padding: 0.4rem 0.75rem;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
      opacity: 0.7;
    }
    .mobile-features .nav-link {
      padding-left: 1.25rem;
      font-size: 0.8rem;
    }
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    .footer-brand { grid-column: span 2; }
    .footer-bottom { flex-direction: column; gap: 0.5rem; text-align: center; }
  }
</style>
