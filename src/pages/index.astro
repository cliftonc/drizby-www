---
import Layout from '../layouts/Layout.astro';

const steps = [
  { num: '1', title: 'Connect', desc: 'Point Drizby at your database. PostgreSQL, MySQL, SQLite, Snowflake, SingleStore, Databend, DuckDB — if Drizzle ORM supports it, so does Drizby.' },
  { num: '2', title: 'Introspect', desc: 'Pull and define your schema via drizzle-kit, then use AI to generate semantic cubes that define your business dimensions and measures.' },
  { num: '3', title: 'Explore', desc: 'Ask questions in plain English, build dashboards visually, and share with your team — unlimited users, no per-seat pricing. Role-based access keeps things secure.' },
];

const features = [
  { title: 'AI-Powered Exploration', desc: 'Ask questions in plain English. Multi-turn AI notebooks generate charts, tables, and insights from your data automatically.', href: '/features/agentic-notebooks', img: '/images/drizby_3.png', alt: 'Agentic AI notebooks' },
  { title: 'Dashboards & Charts', desc: 'Drag-and-drop grid dashboards with bar, line, area, pie, scatter, KPI cards, and data tables. No code required.', href: '/features/dashboards', img: '/images/drizby_2.png', alt: 'Drag-and-drop dashboards' },
  { title: 'Semantic Layer', desc: 'Define metrics once with your existing Drizzle schemas. Access them everywhere — dashboards, APIs, or AI agents.', href: '/features/semantic-layer', img: '/images/drizby_5.png', alt: 'Semantic layer editor' },
  { title: 'AI Agent Ready', desc: 'Expose your data to Claude, Copilot, and Cursor through the Model Context Protocol with OAuth 2.1 authentication.', href: '/features/mcp-server', img: '/images/drizby_1.png', alt: 'MCP server for AI agents' },
  { title: 'Unlimited Users', desc: 'No per-seat pricing. Role-based access, group visibility, and 7 authentication methods including Google, GitHub, GitLab, Microsoft, and Slack.', href: '/features/users-and-groups', img: '/images/drizby_groups.png', alt: 'Users and groups management' },
];

const databases = [
  {
    category: 'PostgreSQL',
    color: '#336791',
    providers: [
      { name: 'PostgreSQL', logo: '/images/db-logos/postgresql.png', url: 'https://www.postgresql.org' },
      { name: 'Neon', logo: '/images/db-logos/neon.png', url: 'https://neon.com' },
      { name: 'Supabase', logo: '/images/db-logos/supabase.png', url: 'https://supabase.com' },
      { name: 'PGlite', logo: '/images/db-logos/pglite.png', url: 'https://pglite.dev' },
      { name: 'AWS Aurora', logo: '/images/db-logos/aws.png', url: 'https://aws.amazon.com/rds/aurora/' },
    ],
  },
  {
    category: 'MySQL',
    color: '#00758f',
    providers: [
      { name: 'MySQL', logo: '/images/db-logos/mysql.png', url: 'https://www.mysql.com' },
      { name: 'PlanetScale', logo: '/images/db-logos/planetscale.png', url: 'https://planetscale.com' },
      { name: 'TiDB', logo: '/images/db-logos/tidb.png', url: 'https://www.pingcap.com' },
    ],
  },
  {
    category: 'SQLite',
    color: '#003b57',
    providers: [
      { name: 'SQLite', logo: '/images/db-logos/sqlite.png', url: 'https://www.sqlite.org' },
      { name: 'Turso', logo: '/images/db-logos/turso.png', url: 'https://turso.tech' },
    ],
  },
  {
    category: 'SingleStore',
    color: '#aa00ff',
    providers: [
      { name: 'SingleStore', logo: '/images/db-logos/singlestore.png', url: 'https://www.singlestore.com' },
    ],
  },
  {
    category: 'Snowflake',
    color: '#29b5e8',
    providers: [
      { name: 'Databend', logo: '/images/db-logos/databend.png', url: 'https://www.databend.com' },
      { name: 'Snowflake', logo: '/images/db-logos/snowflake.png', url: 'https://www.snowflake.com' },
    ],
  },
  {
    category: 'DuckDB',
    color: '#fff000',
    providers: [
      { name: 'DuckDB', logo: '/images/db-logos/duckdb.png', url: 'https://duckdb.org' },
    ],
  },
];

const heroDBs = [
  { name: 'PostgreSQL', logo: '/images/db-logos/postgresql.png' },
  { name: 'MySQL', logo: '/images/db-logos/mysql.png' },
  { name: 'SQLite', logo: '/images/db-logos/sqlite.png' },
  { name: 'Snowflake', logo: '/images/db-logos/snowflake.png' },
  { name: 'DuckDB', logo: '/images/db-logos/duckdb.png' },
  { name: 'SingleStore', logo: '/images/db-logos/singlestore.png' },
  { name: 'Databend', logo: '/images/db-logos/databend.png' },
  { name: 'Neon', logo: '/images/db-logos/neon.png' },
  { name: 'Supabase', logo: '/images/db-logos/supabase.png' },
  { name: 'Turso', logo: '/images/db-logos/turso.png' },
  { name: 'PlanetScale', logo: '/images/db-logos/planetscale.png' },
  { name: 'PGlite', logo: '/images/db-logos/pglite.png' },
  { name: 'TiDB', logo: '/images/db-logos/tidb.png' },
  { name: 'AWS Aurora', logo: '/images/db-logos/aws.png' },
];

const faqs = [
  { q: 'What is Drizby?', a: 'Drizby is an open-source AI analytics platform powered by drizzle-cube. It provides dashboards, agentic AI notebooks, a visual analysis builder, and a full semantic layer — all in a single self-hostable application.' },
  { q: 'Is Drizby free?', a: 'Yes. Drizby is MIT licensed and free to self-host with unlimited users, dashboards, and notebooks. Drizby Cloud is a paid managed hosting option with usage-based pricing.' },
  { q: 'Do you store any of my data?', a: 'No. Drizby connects directly to your databases and queries pass through in real time. We never copy, cache, or store your data.' },
  { q: 'What databases does Drizby support?', a: 'Drizby supports PostgreSQL (including Neon, Supabase, and AWS Aurora), MySQL (including PlanetScale and TiDB), SQLite (including Turso), Snowflake, SingleStore, Databend, and DuckDB — any database supported by Drizzle ORM.' },
  { q: 'What is the semantic layer?', a: 'The semantic layer is powered by drizzle-cube. It lets you define metrics, dimensions, and measures once and access them everywhere — dashboards, APIs, AI agents, and MCP clients. It enforces consistent definitions and security context across all queries.' },
  { q: 'Can AI assistants query my data?', a: 'Yes. Drizby includes an MCP (Model Context Protocol) server with OAuth 2.1 authentication. AI assistants like Claude, VS Code Copilot, and Cursor can query your semantic layer directly with per-user security context.' },
];

const alternatives = [
  { q: 'Is Drizby an alternative to Hex?', a: 'Yes. Like Hex, Drizby offers AI-powered notebooks for data exploration. Unlike Hex, Drizby is open source, self-hostable, includes a full semantic layer, and has no per-seat pricing. You also keep full control of your data — Drizby connects directly to your databases without copying or storing anything.' },
  { q: 'Is Drizby an alternative to Metabase?', a: 'Yes. Drizby provides dashboards, a visual query builder, and multi-database support like Metabase. Drizby adds agentic AI notebooks, a code-first semantic layer powered by drizzle-cube, an MCP server for AI assistants, and native TypeScript/Drizzle ORM integration.' },
  { q: 'Is Drizby an alternative to Apache Superset?', a: 'Yes. Drizby covers similar ground to Superset — dashboards, charts, and multi-database connectivity. Drizby is lighter weight, ships as a single Docker container, includes AI notebooks and an MCP server out of the box, and uses a TypeScript semantic layer instead of SQL-based metrics.' },
];

const pageTitle = 'Drizby - Open-source AI Analytics powered by drizzle-cube';
const pageDescription = 'Connect your database and start exploring with AI. Dashboards, agentic notebooks, and a semantic layer — open source, self-hostable, unlimited users.';
const url = 'https://www.drizby.com';
const ogImage = `${url}/images/drizby_3.png`;
---

<Layout title={pageTitle} description={pageDescription} ogImage={ogImage} canonicalPath="">
  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Drizby",
    "description": pageDescription,
    "url": url,
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Docker",
    "license": "https://opensource.org/licenses/MIT",
    "image": ogImage,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "sourceOrganization": { "@type": "Organization", "name": "Guidemode Limited", "url": "https://guidemode.dev" },
    "potentialAction": { "@type": "ViewAction", "name": "Try Drizby Cloud", "target": "https://cloud.drizby.com/register" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [...faqs, ...alternatives].map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />

  <header class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">Open-source BI platform</p>
        <h1>Your data,<br/>one question away</h1>
        <p class="subtitle">Connect your database and start exploring with AI-powered notebooks, drag-and-drop dashboards, and a full semantic layer. Unlimited users. No per-seat pricing.</p>
        <div class="hero-buttons">
          <a class="btn btn-primary btn-lg" href="https://cloud.drizby.com/register" target="_blank" rel="noopener">Try Drizby Cloud <span class="btn-sub">free during launch</span></a>
          <a class="btn btn-outline btn-lg" href="#self-host">Self-Host Free <span class="btn-sub">MIT licensed</span></a>
        </div>
      </div>
      <div class="hero-visual">
        <img src="/images/drizby_3.png" alt="Drizby AI notebooks" loading="eager" />
      </div>
    </div>
    <div class="hero-dbs">
      <p class="hero-dbs-label">Works with</p>
      <div class="hero-dbs-grid">
        {heroDBs.map(({ name, logo }) => (
          <div class="hero-db" title={name}>
            <img src={logo} alt={`${name} logo`} loading="eager" />
            <span class="hero-db-name">{name}</span>
          </div>
        ))}
      </div>
    </div>
  </header>

  <main>
    <!-- How it works -->
    <section class="steps">
      <h2 class="section-title">Up and running in 2 minutes</h2>
      <div class="steps-flow">
        {steps.map(({ num, title, desc }, i) => (
          <div class="step">
            <div class="step-header">
              <span class="step-num">{num}</span>
              <h3>{title}</h3>
            </div>
            <p>{desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Quickstart video -->
    <section class="video-section">
      <div class="video-container" id="yt-facade">
        <img
          src="https://i.ytimg.com/vi/vv9IYUVit9I/sddefault.jpg"
          alt="Watch: Drizby Quickstart"
          class="video-thumb"
          loading="lazy"
        />
        <button class="video-play" aria-label="Play video">
          <svg width="68" height="48" viewBox="0 0 68 48">
            <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="red"/>
            <path d="M 45,24 27,14 27,34" fill="white"/>
          </svg>
        </button>
      </div>
    </section>

    <!-- Features -->
    <section class="features">
      <h2 class="section-title">Everything you need to understand your data</h2>
      <div class="features-list">
        {features.map(({ title, desc, href, img, alt }, i) => (
          <div class:list={["feature-row", `feature-row-${i % 2 === 0 ? 'normal' : 'flipped'}`]}>
            <div class="feature-text">
              <h3>{title}</h3>
              <p>{desc}</p>
              <a href={href} class="feature-link">Learn more &rarr;</a>
            </div>
            <div class="feature-img">
              <img src={img} alt={alt} loading="lazy" />
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Get started -->
    <section class="get-started" id="self-host">
      <h2 class="section-title">Get started</h2>
      <div class="get-started-grid">
        <div class="get-started-option">
          <h3>Self-host free</h3>
          <p>MIT licensed. No limits. Run it on your own infrastructure with Docker.</p>
          <div class="docker-cmd">
            <pre><code>docker run -p 3461:3461 -v drizby-data:/app/data ghcr.io/cliftonc/drizby:main</code></pre>
            <button class="copy-btn" aria-label="Copy to clipboard" onclick="navigator.clipboard.writeText('docker run -p 3461:3461 -v drizby-data:/app/data ghcr.io/cliftonc/drizby:main').then(()=>{this.classList.add('copied');setTimeout(()=>this.classList.remove('copied'),1500)})">
              <svg class="icon-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <svg class="icon-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          </div>
          <p class="get-started-hint">Then open <a href="http://localhost:3461" target="_blank" rel="noopener">localhost:3461</a></p>
        </div>
        <div class="get-started-divider">
          <span>or</span>
        </div>
        <div class="get-started-option get-started-cloud">
          <h3>Drizby Cloud <span class="cloud-badge">New</span></h3>
          <p>Skip the setup. Deploy a fully managed instance in seconds. Free during initial launch.</p>
          <div class="get-started-buttons">
            <a class="btn btn-cloud" href="https://cloud.drizby.com/register" target="_blank" rel="noopener">Register</a>
            <a class="btn btn-cloud-outline" href="https://cloud.drizby.com/login" target="_blank" rel="noopener">Login</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Privacy -->
    <section class="privacy">
      <h2 class="section-title">Your data stays yours</h2>
      <div class="privacy-row">
        <div class="privacy-item">
          <h3>Dedicated instances</h3>
          <p>Every Cloud customer gets their own isolated instance. Never shared or co-mingled.</p>
        </div>
        <div class="privacy-divider"></div>
        <div class="privacy-item">
          <h3>Your own AI key</h3>
          <p>Bring your own API key. AI queries go directly to your provider — we never see them.</p>
        </div>
        <div class="privacy-divider"></div>
        <div class="privacy-item">
          <h3>Zero caching</h3>
          <p>Queries pass through in real time. We never copy, cache, or store your data.</p>
        </div>
      </div>
      <p class="privacy-link">Read more about our <a href="/security">security and compliance</a> practices.</p>
    </section>

    <!-- Databases -->
    <section class="databases">
      <h2 class="section-title">Works with your database</h2>
      <p class="databases-subtitle">Any database supported by Drizzle ORM</p>
      <div class="db-flat">
        {databases.map(({ category, providers }) => (
          <div class="db-group">
            <span class="db-group-label">{category}</span>
            <div class="db-group-logos">
              {providers.map(({ name, logo, url }) => (
                <a href={url} target="_blank" rel="noopener" class="db-chip" title={name}>
                  <img src={logo} alt={`${name} logo`} loading="lazy" />
                  <span>{name}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Open source -->
    <section class="open-source">
      <h2 class="section-title">Open source, built on open source</h2>
      <p class="os-desc">Drizby is MIT licensed and built on <a href="https://github.com/cliftonc/drizzle-cube" target="_blank" rel="noopener">drizzle-cube</a>, an open-source semantic layer for Drizzle ORM.</p>
      <div class="os-buttons">
        <a class="btn" href="https://github.com/cliftonc/drizby" target="_blank" rel="noopener"><svg class="gh-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg> Drizby on GitHub</a>
        <a class="btn" href="https://github.com/cliftonc/drizzle-cube" target="_blank" rel="noopener"><svg class="gh-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg> drizzle-cube</a>
        <a class="btn btn-secondary" href="https://try.drizzle-cube.dev" target="_blank" rel="noopener">Try Drizzle-Cube Playground</a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map(({ q, a }) => (
          <details class="faq-item">
            <summary>{q}</summary>
            <p>{a}</p>
          </details>
        ))}
      </div>
      <p class="faq-more">Have questions about pricing? See our <a href="/pricing">pricing FAQ</a>.</p>
    </section>

    <section class="faq alternatives">
      <h2 class="section-title">Alternatives</h2>
      <div class="faq-list">
        {alternatives.map(({ q, a }) => (
          <details class="faq-item">
            <summary>{q}</summary>
            <p>{a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- Final CTA -->
    <section class="final-cta">
      <h2>Ready to explore your data?</h2>
      <p>Pay only for what you use, with a generous free period to explore.</p>
      <div class="final-cta-buttons">
        <a class="btn btn-primary" href="https://cloud.drizby.com/register" target="_blank" rel="noopener">Try Drizby Cloud</a>
        <a class="btn" href="https://github.com/cliftonc/drizby" target="_blank" rel="noopener"><svg class="gh-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg> Self-Host Free</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* ============================================
     HERO — Split layout, left-aligned
     ============================================ */
  .hero {
    padding: 5rem 0 0;
  }
  .hero-inner {
    max-width: 1150px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    align-items: center;
  }
  .hero-content {
    text-align: left;
  }
  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 1rem;
  }
  h1 {
    font-size: 3.25rem;
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.05;
    color: var(--text);
  }
  .subtitle {
    margin-top: 1.25rem;
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 480px;
    line-height: 1.65;
  }
  .hero-buttons {
    margin-top: 2rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .hero-visual {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 24px 48px -12px rgba(0, 0, 0, 0.25);
  }
  .hero-visual img {
    width: 100%;
    display: block;
  }

  /* Hero database strip */
  .hero-dbs {
    max-width: 1150px;
    margin: 2.5rem auto 0;
    padding: 0 0 3rem;
    text-align: center;
  }
  .hero-dbs-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-bottom: 0.75rem;
    font-weight: 500;
  }
  .hero-dbs-grid {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    gap: 0.15rem;
    margin: 0 auto;
  }
  .hero-db {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 0.5rem;
    border-radius: 6px;
    transition: background 0.15s, transform 0.15s;
    cursor: default;
  }
  .hero-db:hover {
    background: var(--surface);
    transform: translateY(-1px);
  }
  .hero-db img {
    width: 28px;
    height: 28px;
    border-radius: 5px;
    object-fit: contain;
  }
