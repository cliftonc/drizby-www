---
import Layout from '../layouts/Layout.astro';

const images = [
  { src: '/images/drizby_1.png', alt: 'Drizby Home - AI-powered data exploration', caption: 'Ask questions about your data in natural language' },
  { src: '/images/drizby_2.png', alt: 'Dashboards - drag-and-drop analytics', caption: 'Drag-and-drop dashboards with rich visualizations' },
  { src: '/images/drizby_3.png', alt: 'Agentic AI Notebooks', caption: 'Agentic AI notebooks with multi-turn conversations' },
  { src: '/images/drizby_4.png', alt: 'Analysis Builder - no-code query builder', caption: 'Visual, no-code analysis builder' },
  { src: '/images/drizby_5.png', alt: 'Semantic Layer - schema and cube editor', caption: 'Full semantic layer editor with Monaco IDE' },
];

const features = [
  { title: 'Semantic Layer', desc: 'Use your existing Drizzle schemas. Define metrics once, access them everywhere — dashboards, APIs, or AI agents.', href: '/features/semantic-layer' },
  { title: 'Dashboards', desc: 'Drag-and-drop grid dashboards with bar, line, area, pie, scatter, KPI cards, and data tables.', href: '/features/dashboards' },
  { title: 'Agentic Notebooks', desc: 'Multi-turn AI conversations about your data. Mixed content blocks, auto-save, and dashboard promotion.', href: '/features/agentic-notebooks' },
  { title: 'MCP Server', desc: 'Expose your semantic layer to AI assistants via Model Context Protocol with OAuth 2.1 authentication.', href: '/features/mcp-server' },
  { title: 'Users & Groups', desc: 'Unlimited users with no per-seat pricing. Role-based access, group visibility, and Google OAuth built in.', href: '/features/users-and-groups' },
];

const databases = [
  {
    category: 'PostgreSQL',
    color: '#336791',
    providers: [
      { name: 'PostgreSQL', logo: '/images/db-logos/postgresql.png', url: 'https://www.postgresql.org' },
      { name: 'Neon', logo: '/images/db-logos/neon.png', url: 'https://neon.com' },
      { name: 'Supabase', logo: '/images/db-logos/supabase.png', url: 'https://supabase.com' },
      { name: 'PGlite', logo: '/images/db-logos/pglite.png', url: 'https://pglite.dev' },
      { name: 'AWS Aurora', logo: '/images/db-logos/aws.png', url: 'https://aws.amazon.com/rds/aurora/' },
    ],
  },
  {
    category: 'MySQL',
    color: '#00758f',
    providers: [
      { name: 'MySQL', logo: '/images/db-logos/mysql.png', url: 'https://www.mysql.com' },
      { name: 'PlanetScale', logo: '/images/db-logos/planetscale.png', url: 'https://planetscale.com' },
      { name: 'TiDB', logo: '/images/db-logos/tidb.png', url: 'https://www.pingcap.com' },
    ],
  },
  {
    category: 'SQLite',
    color: '#003b57',
    providers: [
      { name: 'SQLite', logo: '/images/db-logos/sqlite.png', url: 'https://www.sqlite.org' },
      { name: 'Turso', logo: '/images/db-logos/turso.png', url: 'https://turso.tech' },
    ],
  },
  {
    category: 'SingleStore',
    color: '#aa00ff',
    providers: [
      { name: 'SingleStore', logo: '/images/db-logos/singlestore.png', url: 'https://www.singlestore.com' },
    ],
  },
  {
    category: 'DuckDB',
    color: '#fff000',
    providers: [
      { name: 'DuckDB', logo: '/images/db-logos/duckdb.png', url: 'https://duckdb.org' },
    ],
  },
];

const pageTitle = 'Drizby - Open-source AI Analytics powered by drizzle-cube';
const pageDescription = 'An open-source AI analytics platform powered by drizzle-cube. Host yourself or host with us — self-service analytics, AI agentic notebooks, and a full semantic layer.';
const url = 'https://www.drizby.com';
const ogImage = `${url}/images/drizby_2.png`;
---

<Layout title={pageTitle} description={pageDescription} ogImage={ogImage} canonicalPath="">
  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Drizby",
    "description": pageDescription,
    "url": url,
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Docker",
    "license": "https://opensource.org/licenses/MIT",
    "image": ogImage,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "sourceOrganization": { "@type": "Person", "name": "Clifton Cunningham", "url": "https://github.com/cliftonc" },
    "potentialAction": { "@type": "ViewAction", "name": "Try Drizby Cloud", "target": "https://cloud.drizby.com/register" }
  })} />

  <header class="hero">
    <div class="hero-inner">
      <div class="brand">
        <img src="/logo.png" alt="Drizby logo" class="logo" />
        <h1>Drizby</h1>
      </div>
      <p class="tagline">An open-source AI analytics platform powered by <a href="https://github.com/cliftonc/drizzle-cube" target="_blank" rel="noopener">drizzle-cube</a></p>
      <p class="subtitle">Host yourself or host with us &mdash; self-service analytics, AI agentic notebooks, and a full semantic layer.</p>
      <div class="hero-buttons">
        <a class="btn" href="https://github.com/cliftonc/drizby" target="_blank" rel="noopener"><svg class="gh-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg> Drizby</a>
        <a class="btn" href="https://github.com/cliftonc/drizzle-cube" target="_blank" rel="noopener"><svg class="gh-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg> drizzle-cube</a>
        <a class="btn btn-secondary" href="https://try.drizzle-cube.dev" target="_blank" rel="noopener">Try Drizzle-Cube</a>
      </div>
      <div class="cloud-banner">
        <div class="cloud-link">
          <img src="/images/cloud-logo.png" alt="Drizby Cloud" class="cloud-icon" />
          <span class="cloud-text">
            <strong>Drizby Cloud</strong> <span class="cloud-badge">New</span><br/>
            Skip the setup &mdash; deploy a fully managed Drizby instance in seconds. Connect your Postgres database and start exploring your data with AI-powered analytics, dashboards, and notebooks. Free during initial launch.
          </span>
          <span class="cloud-actions">
            <a href="https://cloud.drizby.com/register" target="_blank" rel="noopener" class="cloud-btn cloud-btn-primary">Register</a>
            <a href="https://cloud.drizby.com/login" target="_blank" rel="noopener" class="cloud-btn">Login</a>
          </span>
        </div>
      </div>
    </div>

    <!-- Decorative flowing lines under buttons, full width -->
    <div class="hero-curves">
      <svg viewBox="0 0 1200 200" preserveAspectRatio="xMidYMid slice" fill="none">
        <path d="M0 60 Q200 20 400 50 T800 30 T1200 55" stroke="url(#g1)" stroke-width="2.5" fill="none" />
        <path d="M0 100 Q300 60 600 100 T1200 80" stroke="url(#g2)" stroke-width="2" fill="none" opacity="0.8" />
        <path d="M0 140 Q250 100 500 130 T900 110 T1200 140" stroke="url(#g3)" stroke-width="1.5" fill="none" opacity="0.6" />
        <path d="M0 170 Q400 140 800 160 T1200 150" stroke="url(#g2)" stroke-width="1" fill="none" opacity="0.4" />
        <circle cx="150" cy="45" r="5" fill="#818cf8" opacity="0.9" />
        <circle cx="400" cy="55" r="6" fill="#6366f1" opacity="0.8" />
        <circle cx="700" cy="35" r="4" fill="#a5b4fc" opacity="0.7" />
        <circle cx="1000" cy="50" r="5" fill="#818cf8" opacity="0.7" />
        <circle cx="250" cy="95" r="4" fill="#c7d2fe" opacity="0.6" />
        <circle cx="550" cy="105" r="5" fill="#6366f1" opacity="0.7" />
        <circle cx="850" cy="85" r="4" fill="#a5b4fc" opacity="0.6" />
        <circle cx="100" cy="135" r="3" fill="#6366f1" opacity="0.5" />
        <circle cx="450" cy="125" r="4" fill="#c7d2fe" opacity="0.5" />
        <circle cx="750" cy="115" r="3" fill="#818cf8" opacity="0.4" />
        <circle cx="950" cy="130" r="4" fill="#a5b4fc" opacity="0.5" />
        <defs>
          <linearGradient id="g1" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#6366f1" stop-opacity="0.3" />
            <stop offset="50%" stop-color="#818cf8" stop-opacity="0.8" />
            <stop offset="100%" stop-color="#6366f1" stop-opacity="0.3" />
          </linearGradient>
          <linearGradient id="g2" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#818cf8" stop-opacity="0.2" />
            <stop offset="50%" stop-color="#a5b4fc" stop-opacity="0.6" />
            <stop offset="100%" stop-color="#818cf8" stop-opacity="0.2" />
          </linearGradient>
          <linearGradient id="g3" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#c7d2fe" stop-opacity="0.1" />
            <stop offset="50%" stop-color="#6366f1" stop-opacity="0.5" />
            <stop offset="100%" stop-color="#c7d2fe" stop-opacity="0.1" />
          </linearGradient>
        </defs>
      </svg>
    </div>
  </header>

  <main>
    <section class="docker">
      <p>One command to get started, then open it <a href="http://localhost:3461" target="_blank" rel="noopener">by clicking here</a>:</p>
      <div class="docker-cmd">
        <pre><code>docker run -p 3461:3461 -v drizby-data:/app/data ghcr.io/cliftonc/drizby:main</code></pre>
        <button class="copy-btn" aria-label="Copy to clipboard" onclick="navigator.clipboard.writeText('docker run -p 3461:3461 -v drizby-data:/app/data ghcr.io/cliftonc/drizby:main').then(()=>{this.classList.add('copied');setTimeout(()=>this.classList.remove('copied'),1500)})">
          <svg class="icon-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          <svg class="icon-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>
    </section>

    <!-- Flow connector: docker -> gallery -->
    <div class="flow-connector">
      <svg viewBox="0 0 1200 150" preserveAspectRatio="xMidYMid meet" fill="none">
        <path d="M 300 0 C 300 75, 900 75, 900 150" stroke="url(#flowG1)" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.6" />
        <path d="M 305 0 C 305 70, 905 80, 905 150" stroke="url(#flowG2)" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.3" />
        <circle r="10" fill="url(#pG1)">
          <animateMotion dur="8s" repeatCount="indefinite" path="M 300 0 C 300 75, 900 75, 900 150" />
          <animate attributeName="opacity" values="0;0.7;0.7;0" keyTimes="0;0.1;0.9;1" dur="8s" repeatCount="indefinite" />
        </circle>
        <circle r="6" fill="url(#pG2)">
          <animateMotion dur="5s" repeatCount="indefinite" path="M 300 0 C 300 75, 900 75, 900 150" begin="2s" />
          <animate attributeName="opacity" values="0;0.6;0.6;0" keyTimes="0;0.1;0.9;1" dur="5s" repeatCount="indefinite" begin="2s" />
        </circle>
        <circle r="4" fill="url(#pG1)">
          <animateMotion dur="3.5s" repeatCount="indefinite" path="M 300 0 C 300 75, 900 75, 900 150" begin="0.5s" />
          <animate attributeName="opacity" values="0;0.5;0.5;0" keyTimes="0;0.1;0.9;1" dur="3.5s" repeatCount="indefinite" begin="0.5s" />
        </circle>
        <defs>
          <linearGradient id="flowG1" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#6366f1" stop-opacity="0.5" />
            <stop offset="50%" stop-color="#818cf8" stop-opacity="1" />
            <stop offset="100%" stop-color="#6366f1" stop-opacity="0.5" />
          </linearGradient>
          <linearGradient id="flowG2" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#a5b4fc" stop-opacity="0.3" />
            <stop offset="50%" stop-color="#c7d2fe" stop-opacity="0.6" />
            <stop offset="100%" stop-color="#a5b4fc" stop-opacity="0.3" />
          </linearGradient>
          <radialGradient id="pG1">
            <stop offset="0%" stop-color="#818cf8" stop-opacity="1" />
            <stop offset="100%" stop-color="#6366f1" stop-opacity="0" />
          </radialGradient>
          <radialGradient id="pG2">
            <stop offset="0%" stop-color="#a5b4fc" stop-opacity="0.8" />
            <stop offset="100%" stop-color="#818cf8" stop-opacity="0" />
          </radialGradient>
        </defs>
      </svg>
    </div>

    <section class="gallery">
      {images.map(({ src, alt, caption }, i) => (
        <>
          <figure>
            <img src={src} alt={alt} loading="lazy" />
            <figcaption>{caption}</figcaption>
          </figure>
          {i < images.length - 1 && (
            <div class="flow-connector flow-connector-sm">
              <svg viewBox="0 0 1200 150" preserveAspectRatio="xMidYMid meet" fill="none">
                <path
                  d={i % 2 === 0
                    ? "M 900 0 C 900 75, 300 75, 300 150"
                    : "M 300 0 C 300 75, 900 75, 900 150"}
                  stroke="url(#flowG1)" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.4"
                />
                <circle r="6" fill="url(#pG1)">
                  <animateMotion
                    dur="6s" repeatCount="indefinite"
                    path={i % 2 === 0
                      ? "M 900 0 C 900 75, 300 75, 300 150"
                      : "M 300 0 C 300 75, 900 75, 900 150"}
                  />
                  <animate attributeName="opacity" values="0;0.6;0.6;0" keyTimes="0;0.1;0.9;1" dur="6s" repeatCount="indefinite" />
                </circle>
                <circle r="3" fill="url(#pG2)">
                  <animateMotion
                    dur="4s" repeatCount="indefinite" begin="1.5s"
                    path={i % 2 === 0
                      ? "M 900 0 C 900 75, 300 75, 300 150"
                      : "M 300 0 C 300 75, 900 75, 900 150"}
                  />
                  <animate attributeName="opacity" values="0;0.4;0.4;0" keyTimes="0;0.1;0.9;1" dur="4s" repeatCount="indefinite" begin="1.5s" />
                </circle>
              </svg>
            </div>
          )}
        </>
      ))}
    </section>

    <!-- Flow connector: gallery -> features -->
    <div class="flow-connector">
      <svg viewBox="0 0 1200 150" preserveAspectRatio="xMidYMid meet" fill="none">
        <path d="M 900 0 C 900 75, 300 75, 300 150" stroke="url(#flowG1)" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.6" />
        <circle r="8" fill="url(#pG1)">
          <animateMotion dur="6s" repeatCount="indefinite" path="M 900 0 C 900 75, 300 75, 300 150" />
          <animate attributeName="opacity" values="0;0.7;0.7;0" keyTimes="0;0.1;0.9;1" dur="6s" repeatCount="indefinite" />
        </circle>
        <circle r="4" fill="url(#pG2)">
          <animateMotion dur="3.5s" repeatCount="indefinite" path="M 900 0 C 900 75, 300 75, 300 150" begin="2s" />
          <animate attributeName="opacity" values="0;0.5;0.5;0" keyTimes="0;0.1;0.9;1" dur="3.5s" repeatCount="indefinite" begin="2s" />
        </circle>
      </svg>
    </div>

    <section class="features">
      <h2 class="section-title">Features</h2>
      <div class="features-grid">
        {features.map(({ title, desc, href }) => (
          <a href={href} class="feature">
            <h3>{title}</h3>
            <p>{desc}</p>
            <span class="feature-link">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Flow connector: features -> databases -->
    <div class="flow-connector">
      <svg viewBox="0 0 1200 150" preserveAspectRatio="xMidYMid meet" fill="none">
        <path d="M 300 0 C 300 75, 900 75, 900 150" stroke="url(#flowG1)" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.6" />
        <circle r="8" fill="url(#pG1)">
          <animateMotion dur="6s" repeatCount="indefinite" path="M 300 0 C 300 75, 900 75, 900 150" />
          <animate attributeName="opacity" values="0;0.7;0.7;0" keyTimes="0;0.1;0.9;1" dur="6s" repeatCount="indefinite" />
        </circle>
        <circle r="4" fill="url(#pG2)">
          <animateMotion dur="3.5s" repeatCount="indefinite" path="M 300 0 C 300 75, 900 75, 900 150" begin="2s" />
          <animate attributeName="opacity" values="0;0.5;0.5;0" keyTimes="0;0.1;0.9;1" dur="3.5s" repeatCount="indefinite" begin="2s" />
        </circle>
      </svg>
    </div>

    <section class="databases">
      <h2 class="section-title">Supported Databases</h2>
      <p class="databases-subtitle">Connect to any database supported by Drizzle ORM</p>
      <div class="db-grid">
        {databases.map(({ category, color, providers }) => (
          <div class="db-category">
            <div class="db-category-header" style={`border-color: ${color}`}>
              <span class="db-category-dot" style={`background: ${color}`} />
              <h3>{category}</h3>
            </div>
            <div class="db-providers">
              {providers.map(({ name, logo, url }) => (
                <a href={url} target="_blank" rel="noopener" class="db-provider">
                  <img src={logo} alt={`${name} logo`} class="db-logo" loading="lazy" />
                  <span class="db-name">{name}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 5rem 1.5rem 0;
    text-align: center;
    background: var(--bg);
    overflow: visible;
  }

  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .brand {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .logo {
    height: 4rem;
    width: auto;
    filter: drop-shadow(0 0 20px rgba(99, 102, 241, 0.4));
  }

  h1 {
    font-size: 4rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, var(--text) 0%, var(--accent-hover) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .tagline {
    margin-top: 1rem;
    font-size: 1.4rem;
    color: var(--muted);
    line-height: 1.4;
  }

  .subtitle {
    margin-top: 1rem;
    font-size: 1.15rem;
    color: var(--text);
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
    opacity: 0.85;
  }

  .hero-buttons {
    margin-top: 2rem;
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.4rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .btn:hover { border-color: var(--accent); color: var(--text); }
  .gh-icon { width: 1em; height: 1em; vertical-align: -0.125em; margin-right: 0.3em; }

  .btn-secondary {
    color: var(--muted);
    border-color: var(--border);
  }
  .btn-secondary:hover {
    color: var(--text);
    border-color: var(--accent);
  }

  /* Hero curves */
  .hero-curves {
    width: 100%;
    margin-top: 1.5rem;
    pointer-events: none;
  }
  .hero-curves svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Cloud banner */
  .cloud-banner {
    margin-top: 2rem;
  }
  .cloud-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.2s;
  }
  .cloud-link:hover {
    border-color: #0891b2;
    color: var(--text);
  }
  .cloud-icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 8px;
  }
  .cloud-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: #0891b2;
    color: #fff;
    vertical-align: middle;
    margin-left: 0.4rem;
  }
  .cloud-text {
    flex: 1;
    font-size: 0.85rem;
    line-height: 1.5;
    text-align: left;
    color: var(--muted);
  }
  .cloud-text strong {
    color: #22d3ee;
    font-size: 0.95rem;
