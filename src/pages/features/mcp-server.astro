---
import Layout from '../../layouts/Layout.astro';

const claudeConfig = `{
  <span class="key">"mcpServers"</span>: {
    <span class="key">"drizby"</span>: {
      <span class="key">"type"</span>: <span class="str">"http"</span>,
      <span class="key">"url"</span>: <span class="str">"https://your-drizby.com/mcp"</span>
    }
  }
}`;

const vscodeConfig = `{
  <span class="key">"servers"</span>: {
    <span class="key">"drizby"</span>: {
      <span class="key">"type"</span>: <span class="str">"http"</span>,
      <span class="key">"url"</span>: <span class="str">"https://your-drizby.com/mcp"</span>
    }
  }
}`;
---

<Layout
  title="MCP Server - Drizby"
  description="Expose your semantic layer to AI assistants like Claude, VS Code Copilot, and Cursor through the Model Context Protocol."
  ogImage="https://www.drizby.com/images/claude_mcp.png"
  canonicalPath="/features/mcp-server"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.drizby.com" },
      { "@type": "ListItem", "position": 2, "name": "Features", "item": "https://www.drizby.com/#features" },
      { "@type": "ListItem", "position": 3, "name": "MCP Server", "item": "https://www.drizby.com/features/mcp-server" }
    ]
  })} />
  <main class="feature-page">
    <a href="/" class="breadcrumb">&larr; Back to Home</a>

    <section class="hero">
      <h1>MCP Server</h1>
      <p class="hero-desc">Expose your semantic layer to AI assistants</p>
    </section>

    <section class="content-section">
      <div class="screenshot-container">
        <figure>
          <img src="/images/claude_mcp.png" alt="Claude Desktop querying Drizby via MCP" loading="lazy" />
          <figcaption>Claude Desktop querying data through Drizby's MCP server</figcaption>
        </figure>
      </div>
    </section>

    <section class="content-section">
      <div class="card card-highlight">
        <h2>Model Context Protocol</h2>
        <p>Drizby implements an MCP server that lets AI assistants like Claude, VS Code Copilot, and Cursor query your data through the semantic layer. Your cubes, measures, and dimensions become tools that any MCP-compatible AI client can use.</p>
      </div>
    </section>

    <section class="content-section">
      <div class="card">
        <h2>OAuth 2.1 Authentication</h2>
        <p>Secure per-user OAuth 2.1 authentication for MCP clients. Each user gets their own credentials and security context, so every query is scoped to their permissions and organisation. No shared API keys -- just standard OAuth flows.</p>
      </div>
    </section>

    <section class="content-section">
      <h2 class="section-title">Setup</h2>
      <div class="config-grid">
        <div class="config-card">
          <h3>Claude Desktop</h3>
          <p class="config-desc">Add to your <code>claude_desktop_config.json</code>:</p>
          <div class="code-block">
            <pre><code set:html={claudeConfig} /></pre>
          </div>
        </div>
        <div class="config-card">
          <h3>VS Code / Cursor</h3>
          <p class="config-desc">Add to your MCP settings:</p>
          <div class="code-block">
            <pre><code set:html={vscodeConfig} /></pre>
          </div>
        </div>
      </div>
    </section>

    <section class="content-section">
      <div class="features-grid">
        <div class="card">
          <h3>Security Context</h3>
          <p>Every MCP query goes through the semantic layer with the authenticated user's security context. Row-level security is enforced automatically -- the AI assistant can only access data the user is permitted to see.</p>
        </div>
        <div class="card">
          <h3>Easy Toggle</h3>
          <p>Enable or disable the MCP server from the settings UI with one click. When disabled, the MCP endpoint returns a clean error. No server restart required.</p>
        </div>
      </div>
    </section>

    <section class="content-section cta-section">
      <div class="cta-buttons">
        <a class="btn btn-primary" href="https://github.com/cliftonc/drizby" target="_blank" rel="noopener">
          <svg class="gh-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
          Get Started
        </a>
        <a class="btn" href="https://cloud.drizby.com/register" target="_blank" rel="noopener">Try Drizby Cloud</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .feature-page {
    max-width: 1150px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .breadcrumb {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 2rem;
    transition: color 0.15s;
  }
  .breadcrumb:hover { color: var(--accent-hover); }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
    padding: 3rem 0;
  }
  .hero h1 {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, var(--text) 0%, var(--accent-hover) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-desc {
    margin-top: 1rem;
    font-size: 1.25rem;
    color: var(--muted);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.5;
  }

  .content-section {
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--text) 0%, var(--accent-hover) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }
  .card:hover { border-color: var(--accent); }
  .card h2 { font-size: 1.3rem; margin-bottom: 0.75rem; }
  .card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .card p { color: var(--muted); line-height: 1.6; font-size: 0.95rem; }

  .card-highlight {
    border-color: rgba(99, 102, 241, 0.3);
    background: linear-gradient(135deg, var(--surface) 0%, rgba(99, 102, 241, 0.05) 100%);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .config-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .config-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }
  .config-card:hover { border-color: var(--accent); }
  .config-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .config-desc {
    color: var(--muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }
  .config-desc code {
    background: rgba(99, 102, 241, 0.1);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.8rem;
    color: var(--accent-hover);
  }

  .code-block {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .code-block pre {
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.8rem;
    line-height: 1.5;
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
  }
  .code-block .key { color: #82aaff; }
  .code-block .str { color: #c3e88d; }

  .screenshot-container figure {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .screenshot-container figure:hover {
    border-color: var(--accent);
    box-shadow: 0 0 30px rgba(99, 102, 241, 0.1);
  }
  .screenshot-container img { width: 100%; display: block; }
  .screenshot-container figcaption {
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    color: var(--muted);
    text-align: center;
  }

  .cta-section { text-align: center; }
  .cta-buttons {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .btn:hover { border-color: var(--accent); color: var(--text); }
  .btn-primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    border-color: var(--accent-hover);
    color: #fff;
  }
  .gh-icon { width: 1em; height: 1em; }

  @media (max-width: 768px) {
    .hero h1 { font-size: 2rem; }
    .features-grid { grid-template-columns: 1fr; }
    .config-grid { grid-template-columns: 1fr; }
  }
</style>
