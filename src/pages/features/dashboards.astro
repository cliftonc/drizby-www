---
import Layout from '../../layouts/Layout.astro';
import ChartGallery from '../../components/ChartGallery';
---

<Layout
  title="Dashboards & Analysis Builder - Drizby"
  description="Drag-and-drop analytics dashboards with rich visualizations and a visual, no-code analysis builder."
  ogImage="https://www.drizby.com/images/drizby_2.png"
  canonicalPath="/features/dashboards"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.drizby.com" },
      { "@type": "ListItem", "position": 2, "name": "Features", "item": "https://www.drizby.com/#features" },
      { "@type": "ListItem", "position": 3, "name": "Dashboards", "item": "https://www.drizby.com/features/dashboards" }
    ]
  })} />
  <main class="feature-page">
    <a href="/" class="breadcrumb">&larr; Back to Home</a>

    <section class="hero hero-img-right">
      <div class="hero-content">
        <h1>Dashboards & Analysis Builder</h1>
        <p class="hero-desc">Drag-and-drop analytics with rich visualizations. Build and share dashboards in minutes, not days.</p>
        <ul class="hero-highlights">
          <li>20 built-in chart types including bar, line, area, pie, scatter, and KPI cards</li>
          <li>Resizable, draggable grid layout with save and restore</li>
          <li>No-code analysis builder inspired by Mixpanel and Amplitude</li>
        </ul>
        <div class="hero-cta">
          <a class="btn btn-primary" href="https://cloud.drizby.com/register" target="_blank" rel="noopener">Try Drizby Cloud</a>
          <a class="btn" href="https://github.com/cliftonc/drizby" target="_blank" rel="noopener">Self-Host Free</a>
        </div>
      </div>
      <div class="hero-visual">
        <img src="/images/drizby_2.png" alt="Drizby dashboard with charts and KPIs" loading="eager" />
      </div>
    </section>

    <section class="content-section">
      <h2 class="section-title">20 Built-in Visualizations</h2>
      <p class="section-intro">Every chart queries your cubes through the semantic layer, not raw SQL. Click any chart type to see a live demo.</p>
      <ChartGallery client:only="react" />
    </section>

    <section class="content-section">
      <div class="features-grid">
        <div class="card">
          <h3>Grid Layout</h3>
          <p>Resizable, draggable portlets with react-grid-layout. Arrange your charts exactly how you want them. Save, load, and reset dashboard configurations with a single click.</p>
        </div>
        <div class="card">
          <h3>Dashboard Features</h3>
          <p>Automatic thumbnail generation for quick previews. Per-dashboard filtering across all portlets. Group-based visibility controls. Promote notebook blocks into dashboards.</p>
        </div>
      </div>
    </section>

    <section class="content-section">
      <h2 class="section-title">Analysis Builder</h2>
      <div class="card card-highlight">
        <p>A visual, no-code query builder inspired by Mixpanel and Amplitude. Select measures and dimensions from your semantic layer, add filters, and see real-time results. No SQL required -- just point and click to explore your data.</p>
      </div>
    </section>

    <section class="content-section">
      <div class="screenshot-container">
        <figure>
          <img src="/images/drizby_4.png" alt="Drizby analysis builder" loading="lazy" />
          <figcaption>Visual, no-code analysis builder with real-time results</figcaption>
        </figure>
      </div>
    </section>

    <section class="content-section cta-section">
      <div class="cta-buttons">
        <a class="btn btn-primary" href="https://github.com/cliftonc/drizby" target="_blank" rel="noopener">
          <svg class="gh-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
          Get Started
        </a>
        <a class="btn" href="https://cloud.drizby.com/register" target="_blank" rel="noopener">Try Drizby Cloud</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .feature-page {
    max-width: 1150px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .breadcrumb {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 2rem;
    transition: color 0.15s;
  }
  .breadcrumb:hover { color: var(--accent-hover); }

  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    margin-bottom: 3rem;
    padding: 3rem 0;
  }
  .hero-img-left {
    grid-template-columns: 1fr 1fr;
  }
  .hero-content {
    text-align: left;
  }
  .hero h1 {
    font-size: 2.75rem;
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.05;
    color: var(--text);
  }
  .hero-desc {
    margin-top: 1rem;
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 480px;
    line-height: 1.65;
  }
  .hero-highlights {
    margin-top: 1.25rem;
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .hero-highlights li {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
    padding-left: 1.1rem;
    position: relative;
  }
  .hero-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.45rem;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
  }
  .hero-cta {
    margin-top: 1.5rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .hero-visual {
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 16px 40px -10px rgba(0, 0, 0, 0.2);
  }
  .hero-visual img {
    width: 100%;
    display: block;
  }

  .content-section {
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }
  .card:hover { border-color: var(--accent); }
  .card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .card p { color: var(--muted); line-height: 1.6; font-size: 0.95rem; }

  .section-intro {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .card-highlight {
    border-color: rgba(8, 145, 178, 0.3);
    background: linear-gradient(135deg, var(--surface) 0%, rgba(8, 145, 178, 0.05) 100%);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .screenshot-container figure {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .screenshot-container figure:hover {
    border-color: var(--accent);
    box-shadow: 0 0 30px rgba(8, 145, 178, 0.1);
  }
  .screenshot-container img { width: 100%; display: block; }
  .screenshot-container figcaption {
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    color: var(--muted);
    text-align: center;
  }

  .cta-section { text-align: center; }
  .cta-buttons {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .btn:hover { border-color: var(--accent); color: var(--text); }
  .btn-primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    border-color: var(--accent-hover);
    color: #fff;
  }
  .gh-icon { width: 1em; height: 1em; }

  @media (max-width: 768px) {
    .hero, .hero-img-left {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .hero-img-left .hero-visual {
      order: -1;
    }
    .hero-content {
      text-align: center;
    }
    .hero-highlights {
      max-width: 400px;
      margin-left: auto;
      margin-right: auto;
    }
    .hero h1 { font-size: 2rem; }
    .features-grid { grid-template-columns: 1fr; }
  }
</style>
